# ─── Server ──────────────────────────────────────────────
PORT=5052
SLURM_PORT=5053
CORS_ORIGIN=http://localhost:5051        # Frontend URL (change for production)
APP_URL=http://localhost:5051            # Used in email links

# ─── Authentication ──────────────────────────────────────
JWT_SECRET=your-strong-secret-here       # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Database ────────────────────────────────────────────
DB_SYNC_ALTER=false                      # Set to true to auto-migrate schema changes

# ─── FTP Configuration (for job file uploads) ───────────
FTP_CONFIG_HOST=192.168.x.x              # Master node IP
FTP_CONFIG_USER=your_ftp_username
FTP_CONFIG_PASSWORD=your_ftp_password
FTP_CONFIG_PORT=21

# ─── Email Configuration (Gmail SMTP) ───────────────────
# To enable email notifications:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Other", then paste the 16-digit password below
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=yourGmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM="HPC Slurm System <noreply@hpc-slurm.com>"

# ─── Feature Toggles ────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=true

# ─── Monitoring ──────────────────────────────────────────
PROMETHEUS_URL=http://192.168.x.x:9090  # Prometheus server URL (Master node IP)
