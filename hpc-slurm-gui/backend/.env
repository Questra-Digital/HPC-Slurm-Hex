PORT=5052
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=YOUR_WEBSERVER_PUBLIC_IP:5051
#CORS_ORIGIN=http://localhost:5051
SLURM_PORT=5053

# Email Configuration (Gmail SMTP)
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Update EMAIL_USER and EMAIL_PASSWORD below
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_digit_app_password
EMAIL_FROM="HPC Slurm System <noreply@hpc-slurm.com>"

# FTP Configuration (Master Node)
FTP_CONFIG_HOST=YOUR_MASTER_LAN_IP
FTP_CONFIG_USER=your_ftp_username
FTP_CONFIG_PASSWORD=your_ftp_password
FTP_CONFIG_PORT=21

# Application URL (for email links)
APP_URL=http://localhost:5051

# Feature Toggle
ENABLE_EMAIL_NOTIFICATIONS=true
PROMETHEUS_URL=http://YOUR_MASTER_LAN_IP:9090