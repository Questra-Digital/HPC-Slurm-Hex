# ─── Slurm Master API ────────────────────────────────────
PORT=5053                                # API port (must match SLURM_PORT in backend .env)
FTP_USER=your_ftp_username               # FTP credentials for downloading uploaded job files
FTP_PASSWORD=your_ftp_password
WEBSERVER_URL=http://your-public-ip:5051 # Public URL of the web GUI (used for download links)
